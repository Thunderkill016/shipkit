{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pres.dev/schema/0.1.0/pres-cycle.schema.json",
  "title": "PRES Evolution Cycle Manifest",
  "description": "Portable index for one Positive Recursive Evolution Standard cycle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "presVersion",
    "cycleId",
    "system",
    "status",
    "objective",
    "autonomy",
    "riskClass",
    "baseline",
    "decision",
    "change",
    "verification",
    "outcome",
    "learning",
    "provenance"
  ],
  "properties": {
    "presVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "cycleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "profile": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "active", "verified", "rejected", "rolled-back", "inconclusive"]
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "stakeholders", "outcomeMetrics", "constraints"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "stakeholders": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "outcomeMetrics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "string" }
      }
    },
    "autonomy": {
      "type": "string",
      "enum": ["A0", "A1", "A2", "A3", "A4"]
    },
    "riskClass": {
      "type": "string",
      "enum": ["R0", "R1", "R2", "R3", "R4"]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capturedAt", "artifactRefs", "knownFailures", "blindSpots"],
      "properties": {
        "capturedAt": { "type": "string", "format": "date-time" },
        "artifactRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "knownFailures": { "type": "array", "items": { "type": "string" } },
        "blindSpots": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates", "selected", "reasoningRef"],
      "properties": {
        "candidates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "selected": { "type": ["string", "null"] },
        "reasoningRef": { "type": "string", "minLength": 1 },
        "researchRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planRef", "changeRefs", "rollbackRef"],
      "properties": {
        "planRef": { "type": "string", "minLength": 1 },
        "changeRefs": { "type": "array", "items": { "type": "string" } },
        "rollbackRef": { "type": "string", "minLength": 1 },
        "deviations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks", "independent", "result", "residualRisks"],
      "properties": {
        "checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "independent": { "type": "boolean" },
        "assessorClass": { "type": "string", "enum": ["self", "internal-independent", "external"] },
        "result": { "type": "string", "enum": ["pass", "fail", "partial", "not-run"] },
        "residualRisks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "metricDeltas", "regressions", "uncertainty"],
      "properties": {
        "verdict": { "type": "string", "enum": ["verified", "rejected", "rolled-back", "inconclusive"] },
        "metricDeltas": { "type": "array", "items": { "type": "string" } },
        "regressions": { "type": "array", "items": { "type": "string" } },
        "uncertainty": { "type": "array", "items": { "type": "string" } },
        "cost": { "type": "string" }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoryRefs", "lessons", "metaChanges", "nextQuestions"],
      "properties": {
        "memoryRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "lessons": { "type": "array", "items": { "type": "string" } },
        "metaChanges": { "type": "array", "items": { "type": "string" } },
        "nextQuestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "baseRevision", "resultRevision", "agentSystems", "humanApprovals", "startedAt", "completedAt"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "baseRevision": { "type": "string", "minLength": 1 },
        "resultRevision": { "type": "string", "minLength": 1 },
        "agentSystems": { "type": "array", "items": { "type": "string" } },
        "humanApprovals": { "type": "array", "items": { "type": "string" } },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9]+(?:\\.[A-Za-z0-9_-]+)+$" },
      "additionalProperties": true
    }
  }
}

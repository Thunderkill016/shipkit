# Copy to apps/web/.env.local

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth adapter: auto | supabase | better-auth
# AUTH_ADAPTER=auto

# ── Preset: supabase-full ─────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Preset: portable-pg (pnpm db:up) ──────────────────────────
# DATABASE_URL=postgresql://shipkit:shipkit@localhost:5432/shipkit
# BETTER_AUTH_SECRET=replace-with-32-plus-char-random-secret!!
# BETTER_AUTH_URL=http://localhost:3000
# AUTH_ADAPTER=better-auth

# ── Optional rate limit ───────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Optional OAuth (Better Auth only) ────────────────────────
# Google: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Optional mail (production) ────────────────────────────────
# RESEND_API_KEY=

# ── Optional storage ──────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=          # for R2/MinIO/DO Spaces

{
  "name": "cyclewarden",
  "version": "0.4.0",
  "private": true,
  "description": "CycleWarden — one AI-native system for researching, building, verifying, shipping and continuously improving products.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "ready": "node scripts/ready.mjs",
    "dev": "pnpm --filter @cyclewarden/evolution-core build && pnpm --filter @cyclewarden/web dev",
    "build": "pnpm --filter @cyclewarden/evolution-core build && pnpm --filter @cyclewarden/web build",
    "start": "pnpm --filter @cyclewarden/web start",
    "lint": "pnpm --filter @cyclewarden/web lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @cyclewarden/web test:e2e",
    "test:sandbox:docker": "pnpm --filter @cyclewarden/evolution-core build && node scripts/test-sandbox-docker.mjs",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/setup.mjs",
    "check:deploy": "node scripts/check-deploy.mjs",
    "check:ai": "node scripts/check-ai-workflow.mjs && node scripts/check-external-systems.mjs && node scripts/test-external-systems.mjs && node scripts/check-a2-pilot.mjs && node scripts/test-a2-pilot.mjs && node scripts/test-create-cyclewarden.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm check:ai",
    "create": "node scripts/create-cyclewarden.mjs",
    "evolve": "pnpm --filter @cyclewarden/evolution-core build && node packages/evolution-core/dist/cli.js",
    "research:public": "pnpm --filter @cyclewarden/evolution-core build && node packages/evolution-core/dist/public-cli.js",
    "sandbox:check": "pnpm --filter @cyclewarden/evolution-core build && node packages/evolution-core/dist/sandbox-cli.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/db-migrate.mjs",
    "research:candidates": "pnpm --filter @cyclewarden/evolution-core build && node packages/evolution-core/dist/candidate-cli.js",
    "research:search": "pnpm --filter @cyclewarden/evolution-core build && node packages/evolution-core/dist/search-cli.js"
  },
  "engines": {
    "node": ">=20.9"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.16",
      "sharp": "0.35.0"
    }
  },
  "devDependencies": {
    "postgres": "^3.4.9"
  }
}

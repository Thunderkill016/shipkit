{
  "name": "shipkit",
  "version": "0.4.0",
  "private": true,
  "description": "Shipkit — one AI-native system for researching, building, verifying, shipping and continuously improving products.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "ready": "node scripts/ready.mjs",
    "dev": "pnpm --filter @shipkit/evolution-core build && pnpm --filter @shipkit/web dev",
    "build": "pnpm --filter @shipkit/evolution-core build && pnpm --filter @shipkit/web build",
    "start": "pnpm --filter @shipkit/web start",
    "lint": "pnpm --filter @shipkit/web lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @shipkit/web test:e2e",
    "test:sandbox:docker": "pnpm --filter @shipkit/evolution-core build && node scripts/test-sandbox-docker.mjs",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/setup.mjs",
    "check:deploy": "node scripts/check-deploy.mjs",
    "check:ai": "node scripts/check-ai-workflow.mjs && node scripts/test-create-shipkit.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm check:ai",
    "create": "node scripts/create-shipkit.mjs",
    "evolve": "pnpm --filter @shipkit/evolution-core build && node packages/evolution-core/dist/cli.js",
    "research:public": "pnpm --filter @shipkit/evolution-core build && node packages/evolution-core/dist/public-cli.js",
    "sandbox:check": "pnpm --filter @shipkit/evolution-core build && node packages/evolution-core/dist/sandbox-cli.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/db-migrate.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "postgres": "^3.4.9"
  }
}

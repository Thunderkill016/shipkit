{
  "name": "@cyclewarden/evolution-core",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic lifecycle, evidence, research and governed execution core for CycleWarden.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cyclewarden-evolve": "./dist/bin-evolve.js",
    "cyclewarden-research-public": "./dist/bin-public-research.js",
    "cyclewarden-sandbox-check": "./dist/bin-sandbox-check.js",
    "cyclewarden-research-candidates": "./dist/bin-candidate-research.js",
    "cyclewarden-research-search": "./dist/bin-public-search.js",
    "cyclewarden-deliver": "./dist/bin-delivery.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "test": "npm run build && vitest run src"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
